# Python / Virtualenv
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
.env.*
!.env.example*
# Never push — local/VPS env examples (may contain secrets)
.env.example.local
.env.example.vps

# Logs & temp files
*.log
*.logs
*.out
*.err
*.bak
*.swp
*.tmp
*.temp

# Editor & OS files
.DS_Store
Thumbs.db
*.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Node.js / Frontend build (if you add npm/yarn later)
node_modules/
dist/
build/
*.min.js
*.map

